{
  "expo": {
    "name": "Eduxity",
    "slug": "eduxity-app",
    "scheme": "eduxity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB",
      "plugins": [
        "expo-router",
        "expo-image-picker",
        "expo-av",
        [
          "react-native-agora",
          {
            "microphonePermission": "Allow Eduxity to access your microphone for Voice Lounge."
          }
        ]
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.abushahma.eduxity",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "e56f89af-152f-4f0f-896c-02dd37f0c5a4"
      }
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-audio",
      "expo-video",
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abushahma.eduxity"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "server"
    }
  }
}
