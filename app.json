{
  "expo": {
    "name": "Eduxity",
    "slug": "eduxity-app",
    "scheme": "eduxity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "notification": {
      "color": "#ffffff"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.abushahma.eduxity",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "e56f89af-152f-4f0f-896c-02dd37f0c5a4"
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-av",
      "expo-audio",
      "expo-video",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "eduxity",
          "organization": "MD ABUSHAHMA AKHTAR"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abushahma.eduxity"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    }
  }
}
