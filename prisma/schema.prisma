// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String  @id @default(uuid())
  email               String  @unique
  name                String?
  firebaseUid         String  @unique
  targetExam          String? @default("JEE")
  preferredTopics     Json?
  preferredDifficulty Int?    @default(2)

  // 🚀 Simplified Gamification Fields (Naya Add Hua Hai)
  totalPoints         Int     @default(0)
  currentStreak       Int     @default(0)

  // Relations
  pushTokens       PushToken[]
  sessions         LearningSession[]
  learningItems    LearningItem[]
  interactions     UserInteraction[]
  feedItems        FeedItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushToken {
  id     String @id @default(uuid())
  token  String @unique
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningSession {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          String
  status         SessionStatus @default(ACTIVE)
  totalGenerated Int           @default(0)
  totalCompleted Int           @default(0)
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  items          LearningItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LearningItem {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId        String?
  session          LearningSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type             LearningItemType
  topic            String
  difficulty       Int              @default(2)
  payload          Json
  isPublished      Boolean          @default(false)
  engagementScore  Float            @default(0)
  masteredByUser   Boolean          @default(false)
  lastInteractedAt DateTime?
  nextReviewAt     DateTime?
  reviewInterval   Int              @default(0)
  reviewCount      Int              @default(0)

  feedItem     FeedItem?
  interactions UserInteraction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([topic, difficulty])
}

model FeedItem {
  id                String       @id @default(uuid())
  learningItemId    String       @unique
  learningItem      LearningItem @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  publishedByUserId String?
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishedAt       DateTime     @default(now())
  createdAt         DateTime     @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model UserInteraction {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningItemId String
  learningItem   LearningItem    @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  type           InteractionType
  isCorrect      Boolean?
  createdAt      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([learningItemId, type])
}

enum LearningItemType {
  quiz
  flashcard
  match
  remember
  mini_game
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

enum InteractionType {
  VIEW
  CORRECT
  WRONG
  SKIP
  SAVE
  LIKE
  SHARE
  BOOKMARK
}