{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "store/**/*.ts",
    "core/**/*.ts",
    "core/**/*.tsx",
    "lib/**/*.ts",
    "shared/**/*.ts",
    "constants/**/*.ts",
    "server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scratch/**",
    "android/**",
    "ios/**",
    "dist/**"
  ]
}
